# ---------------------------------------------------------------------------
# Library of Timbuktu — environment variables
# Copy this file to `.env.local` and fill in the values. Never commit .env.local.
# ---------------------------------------------------------------------------

# Supabase project URL (Project Settings → API). Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (Project Settings → API). Safe to expose; RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (Project Settings → API). SERVER ONLY — bypasses RLS.
# Never prefix with NEXT_PUBLIC_ and never import into client components.
SUPABASE_SERVICE_ROLE_KEY=
